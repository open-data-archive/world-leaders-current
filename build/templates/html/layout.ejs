<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <meta name="description" content="<%= description %>">
  <link rel="canonical" href="https://open-data-archive.github.io<%= basePath %><%= canonical || '' %>">
  <script type="application/ld+json"><%- jsonLd %></script>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; line-height: 1.6; color: #1a1a1a; max-width: 1100px; margin: 0 auto; padding: 1rem; }
    header { border-bottom: 2px solid #e5e7eb; padding-bottom: 1rem; margin-bottom: 2rem; }
    header h1 { font-size: 1.5rem; }
    header p { color: #6b7280; font-size: 0.9rem; }
    nav { margin: 1rem 0; font-size: 0.85rem; }
    nav a { color: #2563eb; text-decoration: none; }
    nav a:hover { text-decoration: underline; }
    table { width: 100%; border-collapse: collapse; margin: 1rem 0; }
    th, td { padding: 0.5rem 0.75rem; text-align: left; border-bottom: 1px solid #e5e7eb; }
    th { background: #f9fafb; font-weight: 600; font-size: 0.85rem; }
    td { font-size: 0.9rem; }
    tr:hover { background: #f9fafb; }
    a { color: #2563eb; text-decoration: none; }
    a:hover { text-decoration: underline; }
    .flag { font-size: 1.2rem; }
    .meta { color: #6b7280; font-size: 0.8rem; margin: 0.5rem 0; }
    .card { border: 1px solid #e5e7eb; border-radius: 8px; padding: 1rem; margin: 1rem 0; }
    .card h3 { margin-bottom: 0.5rem; }
    .api-note { background: #f0f9ff; border: 1px solid #bae6fd; border-radius: 6px; padding: 0.75rem; margin: 1.5rem 0; font-size: 0.85rem; }
    footer { margin-top: 3rem; padding-top: 1rem; border-top: 1px solid #e5e7eb; color: #6b7280; font-size: 0.8rem; }
  </style>
</head>
<body>
  <header>
    <h1><a href="<%= basePath %>">World Leaders Current</a></h1>
    <p>Heads of state and government for ASEAN + G20 — updated daily from Wikipedia</p>
  </header>
  <nav>
    <a href="<%= basePath %>">Home</a> |
    <a href="<%= basePath %>countries/">Countries</a> |
    <a href="<%= basePath %>api/v1/all.json">API</a> |
    <a href="https://github.com/open-data-archive/world-leaders-current">GitHub</a>
  </nav>
  <%- content %>
  <footer>
    <p>Data sourced from <a href="https://www.wikipedia.org/">Wikipedia</a> and <a href="https://www.wikidata.org/">Wikidata</a> under CC-BY-SA-4.0. Updated: <%= snapshotDate %></p>
  </footer>
</body>
</html>
